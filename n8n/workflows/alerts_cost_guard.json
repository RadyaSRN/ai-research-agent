    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO alert_buckets (alert_key, bucket_id, cost_value, threshold_value)\nVALUES (\n  'cost_hourly',\n  to_char(now() AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24'),\n  {{ $json.cost_value }},\n  {{ $json.threshold }}\n)\nON CONFLICT (alert_key, bucket_id) DO NOTHING\nRETURNING bucket_id, cost_value, threshold_value;",
        "options": {}
      },
