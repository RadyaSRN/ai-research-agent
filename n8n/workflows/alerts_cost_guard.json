      "name": "Langfuse cost 1h",
      "retryOnFail": true,
      "credentials": {
        "httpBasicAuth": {
          "id": "msuHs7srJe4fcu64",
          "name": "Langfuse API"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json?.data || [];\nlet total = 0;\nfor (const bucket of data) {\n  total += Number(bucket.totalCost) || 0;\n}\nreturn [{ json: { cost_value: Number(total.toFixed(6)), threshold: 1.0 } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ],
      "id": "00e43fab-9178-49c2-86c7-6dc103ac469e",
      "name": "Sum cost 1h"
    },
    {
      "parameters": {
        "conditions": {
