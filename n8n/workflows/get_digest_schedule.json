        "query": "SELECT\n  is_enabled,\n  send_time::TEXT,\n  timezone,\n  next_run_at,\n  last_run_at\nFROM digest_schedules\nWHERE user_id = '{{ $('Set').item.json.user_id }}'\nLIMIT 1;",
