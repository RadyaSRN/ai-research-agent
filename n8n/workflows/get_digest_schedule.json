    {
      "parameters": {
        "jsCode": "if (items.length === 0 || !items[0].json.send_time) {\n  return [{\n    json: {\n      success: true,\n      schedule: null,\n      message: \"No digest schedule configured for this user.\"\n    }\n  }];\n}\nconst s = items[0].json;\nreturn [{\n  json: {\n    success: true,\n    schedule: {\n      is_enabled: s.is_enabled,\n      send_time: s.send_time,\n      timezone: s.timezone,\n      next_run_at: s.next_run_at,\n      last_run_at: s.last_run_at,\n    }\n  }\n}];"
