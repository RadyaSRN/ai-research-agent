      "name": "HTTP Request (arxiv)"
    },
    {
      "parameters": {
        "jsCode": "const xml = $input.first().json.data;\n\nif (!xml || typeof xml !== \"string\") {\n  throw new Error(\"Не найден XML-текст в ответе HTTP Request\");\n}\n\nfunction getAllMatches(text, regex) {\n  return [...text.matchAll(regex)].map((match) => match[1]?.trim()).filter(Boolean);\n}\n\nfunction getFirstMatch(text, regex) {\n  return text.match(regex)?.[1]?.trim() ?? null;\n}\n\nfunction cleanupText(text) {\n  return text.replace(/\\s+/g, \" \").trim();\n}\n\nconst entries = [...xml.matchAll(/<entry>([\\s\\S]*?)<\\/entry>/g)].map((match) => match[1]);\n\nconst items = entries.map((entry) => {\n  const rawId = getFirstMatch(entry, /<id>(.*?)<\\/id>/);\n  const arxivId = rawId ? rawId.split(\"/abs/\").pop() : null;\n\n  const title = cleanupText(getFirstMatch(entry, /<title>([\\s\\S]*?)<\\/title>/) ?? \"\");\n  const abstract = cleanupText(getFirstMatch(entry, /<summary>([\\s\\S]*?)<\\/summary>/) ?? \"\");\n\n  const authors = getAllMatches(entry, /<name>([\\s\\S]*?)<\\/name>/g).map(cleanupText);\n  const categories = getAllMatches(entry, /<category[^>]*term=\"([^\"]+)\"[^>]*\\/?>/g);\n\n  const publishedAt = getFirstMatch(entry, /<published>(.*?)<\\/published>/);\n  const updatedAtArxiv = getFirstMatch(entry, /<updated>(.*?)<\\/updated>/);\n\n  const url = getFirstMatch(entry, /<id>(.*?)<\\/id>/);\n  const pdfUrl =\n    getFirstMatch(entry, /<link[^>]*title=\"pdf\"[^>]*href=\"([^\"]+)\"[^>]*\\/?>/) ??\n    (url ? url.replace(\"/abs/\", \"/pdf/\") + \".pdf\" : null);\n\n  return {\n    json: {\n      arxiv_id: arxivId,\n      title,\n      abstract,\n      authors,\n      categories,\n      authors_sql: `{${authors.map((value) => `\"${value.replace(/\"/g, '\\\\\"')}\"`).join(\",\")}}`,\n      categories_sql: `{${categories.map((value) => `\"${value.replace(/\"/g, '\\\\\"')}\"`).join(\",\")}}`,\n      published_at: publishedAt,\n      updated_at_arxiv: updatedAtArxiv,\n      url,\n      pdf_url: pdfUrl,\n      ingested_via: \"ondemand_search\",\n    },\n  };\n}).filter((item) => {\n  return !!(item.json.arxiv_id && item.json.title && item.json.abstract);\n});\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
