        "jsCode": "const allPapers = $(\"Parse XML\").all().map(i => i.json);\n\nreturn [{\n  json: {\n    success: true,\n    count: allPapers.length,\n    papers: allPapers.map(p => ({\n      arxiv_id: p.arxiv_id,\n      title: p.title,\n      authors: p.authors,\n      abstract: p.abstract,\n      url: p.url,\n      published_at: p.published_at,\n      categories: p.categories,\n    })),\n  }\n}];"
