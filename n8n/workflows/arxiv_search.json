    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO papers (arxiv_id, title, abstract, authors, categories, published_at, updated_at_arxiv, url, pdf_url, ingested_via)\nVALUES (\n  '{{ $json.arxiv_id }}',\n  $${{ $json.title }}$$,\n  $${{ $json.abstract }}$$,\n  '{{ $json.authors_sql }}'::text[],\n  '{{ $json.categories_sql }}'::text[],\n  '{{ $json.published_at }}'::timestamptz,\n  '{{ $json.updated_at_arxiv }}'::timestamptz,\n  '{{ $json.url }}',\n  '{{ $json.pdf_url }}',\n  'ondemand_search'\n)\nON CONFLICT (arxiv_id) DO NOTHING\nRETURNING id, arxiv_id;",
        "options": {}
      },
