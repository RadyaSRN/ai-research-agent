    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"relevance_score\": 7,\n  \"reasoning\": \"The paper is relevant because it uses similar methodology and addresses a closely related problem.\",\n  \"key_concepts_matched\": [\"diffusion guidance\", \"hidden activations\"]\n}"
      },
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        1552,
        192
      ],
      "id": "f2594f4b-92d0-4883-9304-88fe96064df1",
      "name": "Structured Output Parser"
    },
    {
      "parameters": {
        "jsCode": "if (!items.length) {\n  return [{ json: { success: false, error: \"idea or paper not found\" } }];\n}\n\nconst sources = $(\"Get idea and paper data\").all().map(s => s.json);\n\nreturn items.map((it, idx) => {\n  const llm = it.json.output;\n  const source = sources[idx];\n  return {\n    json: {\n      success: true,\n      idea_id: source.idea_id,\n      paper_id: source.paper_id,\n      idea_title: source.idea_title,\n      idea_description: source.idea_description,\n      paper_title: source.paper_title,\n      paper_abstract: source.paper_abstract,\n      relevance_score: llm.relevance_score,\n      reasoning: llm.reasoning,\n      key_concepts_matched: llm.key_concepts_matched,\n    },\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
