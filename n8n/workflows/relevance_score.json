      "id": "07dd515f-7f12-452d-91f8-566d4460e702",
      "name": "Get system prompt from Langfuse",
      "credentials": {
        "langfuseApi": {
          "id": "gqKtUnj5w09uIlCr",
          "name": "Langfuse account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const templates = $input.all();\nconst sources = $('Get idea and paper data').all();\n\nreturn templates.map((t, idx) => {\n  const template = t.json.prompt;\n  const src = sources[idx].json;\n  const vars = {\n    idea_title: src.idea_title,\n    idea_description: src.idea_description,\n    idea_keywords: Array.isArray(src.idea_keywords)\n      ? src.idea_keywords.join(', ')\n      : (src.idea_keywords ?? ''),\n    paper_title: src.paper_title,\n    paper_abstract: src.paper_abstract,\n  };\n  let compiled = template;\n  for (const [k, v] of Object.entries(vars)) {\n    compiled = compiled.replace(new RegExp(`{{\\\\s*${k}\\\\s*}}`, 'g'), String(v ?? ''));\n  }\n  return { json: { ...src, prompt: compiled } };\n});\n"
      },
