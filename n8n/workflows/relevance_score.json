    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  i.id as idea_id,\n  i.title as idea_title,\n  i.description as idea_description,\n  i.keywords as idea_keywords,\n  p.id as paper_id,\n  p.title as paper_title,\n  p.abstract as paper_abstract\nFROM ideas i\nJOIN papers p ON p.arxiv_id = '{{$('Set').item.json.paper_id}}'\nWHERE i.id = '{{$('Set').item.json.idea_id}}'\nLIMIT 1;",
        "options": {}
      },
