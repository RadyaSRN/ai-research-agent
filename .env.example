# ============================================================================
# AI Research Agent — environment variables
# ============================================================================
# Скопируйте этот файл в .env (`cp .env.example .env`) и заполните значения.
# Генераторы секретов подсказаны в комментариях рядом с каждой переменной.
# Файл .env добавлен в .gitignore — не коммитьте его.
# ============================================================================


# ──────── Hosts & TLS ────────
# Домены, под которыми будут раздаваться n8n и Langfuse через Caddy.
# Для локального теста достаточно localhost + порт-форвардинга, либо
# добавить в /etc/hosts: `127.0.0.1 n8n.example.test langfuse.example.test`.
N8N_HOST=n8n.example.test
LANGFUSE_HOST=langfuse.example.test
# Email для Let's Encrypt (Caddy). Для локала можно оставить любой.
ACME_EMAIL=you@example.com


# ──────── Postgres (shared: n8n + приложение) ────────
POSTGRES_USER=postgres
# openssl rand -hex 32
POSTGRES_PASSWORD=
# БД, которую поднимает Postgres-контейнер; приложение использует также БД `app`,
# которая создаётся скриптом postgres/init.sql при первом запуске.
POSTGRES_DB=n8n


# ──────── n8n ────────
# КРИТИЧНО: openssl rand -hex 32. Менять после первого запуска НЕЛЬЗЯ — все
# сохранённые credentials окажутся нерасшифровываемыми.
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_USER=admin
# openssl rand -hex 32
N8N_BASIC_AUTH_PASSWORD=
# Оставляем всё telemetry-подобное выключенным.
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_TEMPLATES_ENABLED=false
# JWT от n8n Public API. Генерируется в UI: Settings → API → Create API key.
# Заполнить после первого запуска n8n, если планируете ходить в его REST API
# (например, из bench/create_dataset.py).
N8N_API_KEY=
# Пустые строки отключают диагностические хуки.
N8N_DIAGNOSTICS_CONFIG_FRONTEND=
N8N_DIAGNOSTICS_CONFIG_BACKEND=
EXTERNAL_FRONTEND_HOOKS_URLS=


# ──────── External APIs ────────
# GitHub PAT для GitHub MCP (используется в telegram_agent). Scope `public_repo`
# достаточно. Сгенерировать: github.com/settings/tokens.
GITHUB_PAT=
# OpenAlex free API key (не обязателен, но повышает rate limit).
# Регистрация: https://openalex.org/
OPENALEX_API_KEY=
# OpenRouter API key — используется внутри n8n credentials (не через env
# прямо), но продублирован здесь как единый источник правды.
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=


# ──────── Langfuse self-hosted (v3) ────────
LANGFUSE_POSTGRES_USER=langfuse
# openssl rand -hex 32
LANGFUSE_POSTGRES_PASSWORD=
LANGFUSE_POSTGRES_DB=langfuse
LANGFUSE_CLICKHOUSE_USER=clickhouse
# openssl rand -hex 32
LANGFUSE_CLICKHOUSE_PASSWORD=
# openssl rand -hex 32
LANGFUSE_REDIS_AUTH=
LANGFUSE_MINIO_ROOT_USER=minio
# openssl rand -hex 24
LANGFUSE_MINIO_ROOT_PASSWORD=
# openssl rand -base64 32
LANGFUSE_NEXTAUTH_SECRET=
# openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=
# openssl rand -hex 16
LANGFUSE_SALT=
LANGFUSE_TELEMETRY_ENABLED=false

# Публичный и секретный ключи проекта в Langfuse. Заполнить после первого
# запуска `docker compose up langfuse-web`: зайти в UI, зарегистрироваться,
# создать проект, Settings → API Keys → Create.
# Используются shipper-ом и bench-скриптами.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=


# ──────── Monitoring / alerts ────────
# ID Telegram-чата, куда воркфлоу alerts_cost_guard и alerts_error_handler
# шлют уведомления. Узнать: отправить любое сообщение @userinfobot, либо
# https://api.telegram.org/bot<TOKEN>/getUpdates после создания бота.
ADMIN_TELEGRAM_CHAT_ID=
